<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mesh_background"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ─── Header with Mesh Icon ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <!-- Mesh network icon -->
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="@color/mesh_accent"
                android:contentDescription="MeshTalk logo"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MeshTalk"
                android:textColor="@color/mesh_primary_text"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Companion"
                android:textColor="@color/mesh_secondary_text"
                android:textSize="14sp"
                android:gravity="center"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="28dp" />
        </LinearLayout>

        <!-- ─── Glasses Connection Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/mesh_surface"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GLASSES"
                    android:textColor="@color/mesh_accent"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/bleStatusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_dot_red"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/bleStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disconnected"
                        android:textColor="@color/mesh_primary_text"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Channel Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/mesh_surface"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CHANNEL"
                    android:textColor="@color/mesh_accent"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/channelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alpha (0)"
                    android:textColor="@color/mesh_accent"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Mesh Network Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/mesh_surface"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MESH NETWORK"
                    android:textColor="@color/mesh_accent"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Peers row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Peers on network"
                        android:textColor="@color/mesh_secondary_text"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/peerCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/mesh_primary_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Thin divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/mesh_divider"
                    android:layout_marginBottom="8dp" />

                <!-- Packets row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Audio packets relayed"
                        android:textColor="@color/mesh_secondary_text"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/packetCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/mesh_primary_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Service Status Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/mesh_surface"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SERVICE"
                    android:textColor="@color/mesh_accent"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/meshStatusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_dot_red"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/serviceStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stopped"
                        android:textColor="@color/mesh_error"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Log Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/mesh_surface"
            app:cardUseCompatPadding="true"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOG"
                    android:textColor="@color/mesh_accent"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/logText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready to start..."
                    android:textColor="@color/mesh_log_text"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="12" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Start/Stop Button ─── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startStopButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START SERVICE"
            android:textSize="16sp"
            android:textColor="@color/mesh_button_text"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/button_start"
            app:backgroundTint="@null"
            app:cornerRadius="20dp"
            android:stateListAnimator="@null"
            android:elevation="4dp" />

    </LinearLayout>
</ScrollView>
